{
  "components": {
    "schemas": {
      "Assumption": {
        "additionalProperties": false,
        "properties": {
          "approved_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Approved At"
          },
          "approved_by": {
            "anyOf": [
              {
                "maxLength": 200,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Approved By"
          },
          "effective_at": {
            "format": "date-time",
            "title": "Effective At",
            "type": "string"
          },
          "entered_at": {
            "format": "date-time",
            "title": "Entered At",
            "type": "string"
          },
          "expires_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expires At"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "key": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Key",
            "type": "string"
          },
          "owner": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Owner",
            "type": "string"
          },
          "rationale": {
            "maxLength": 2000,
            "minLength": 1,
            "title": "Rationale",
            "type": "string"
          },
          "scenario_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scenario Id"
          },
          "source_gap": {
            "maxLength": 1000,
            "minLength": 1,
            "title": "Source Gap",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/AssumptionStatus",
            "default": "DRAFT"
          },
          "supersedes_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Supersedes Id"
          },
          "truth_class": {
            "$ref": "#/components/schemas/TruthClass",
            "default": "ASSUMPTION"
          },
          "unit": {
            "maxLength": 50,
            "minLength": 1,
            "title": "Unit",
            "type": "string"
          },
          "value": {
            "title": "Value"
          }
        },
        "required": [
          "key",
          "value",
          "unit",
          "rationale",
          "source_gap",
          "owner",
          "entered_at",
          "effective_at"
        ],
        "title": "Assumption",
        "type": "object"
      },
      "AssumptionStatus": {
        "enum": [
          "DRAFT",
          "APPROVED",
          "EXPIRED",
          "SUPERSEDED"
        ],
        "title": "AssumptionStatus",
        "type": "string"
      },
      "AuditEvent": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Action",
            "type": "string"
          },
          "actor_id": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Actor Id",
            "type": "string"
          },
          "actor_type": {
            "maxLength": 50,
            "minLength": 1,
            "title": "Actor Type",
            "type": "string"
          },
          "after_hash": {
            "anyOf": [
              {
                "pattern": "^[a-fA-F0-9]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "After Hash"
          },
          "before_hash": {
            "anyOf": [
              {
                "pattern": "^[a-fA-F0-9]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Before Hash"
          },
          "causation_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Causation Id"
          },
          "correlation_id": {
            "format": "uuid",
            "title": "Correlation Id",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "occurred_at": {
            "format": "date-time",
            "title": "Occurred At",
            "type": "string"
          },
          "outcome": {
            "$ref": "#/components/schemas/AuditOutcome"
          },
          "reason": {
            "anyOf": [
              {
                "maxLength": 2000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          },
          "resource_id": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Resource Id",
            "type": "string"
          },
          "resource_type": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Resource Type",
            "type": "string"
          }
        },
        "required": [
          "occurred_at",
          "actor_id",
          "actor_type",
          "action",
          "resource_type",
          "resource_id",
          "correlation_id",
          "outcome"
        ],
        "title": "AuditEvent",
        "type": "object"
      },
      "AuditOutcome": {
        "enum": [
          "SUCCEEDED",
          "FAILED",
          "BLOCKED"
        ],
        "title": "AuditOutcome",
        "type": "string"
      },
      "DataMode": {
        "enum": [
          "LIVE",
          "CACHED",
          "REPLAY",
          "FIXTURE",
          "USER_SUPPLIED"
        ],
        "title": "DataMode",
        "type": "string"
      },
      "EvidenceRecord": {
        "additionalProperties": false,
        "properties": {
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "dataset": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Dataset",
            "type": "string"
          },
          "dataset_version": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Dataset Version",
            "type": "string"
          },
          "effective_at": {
            "format": "date-time",
            "title": "Effective At",
            "type": "string"
          },
          "fetched_at": {
            "format": "date-time",
            "title": "Fetched At",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "license": {
            "maxLength": 500,
            "minLength": 1,
            "title": "License",
            "type": "string"
          },
          "mode": {
            "$ref": "#/components/schemas/DataMode"
          },
          "parent_evidence_ids": {
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "title": "Parent Evidence Ids",
            "type": "array"
          },
          "raw_object_ref": {
            "anyOf": [
              {
                "maxLength": 1000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Object Ref"
          },
          "raw_payload_hash": {
            "pattern": "^[a-fA-F0-9]{64}$",
            "title": "Raw Payload Hash",
            "type": "string"
          },
          "source_id": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Source Id",
            "type": "string"
          },
          "source_record_id": {
            "maxLength": 500,
            "minLength": 1,
            "title": "Source Record Id",
            "type": "string"
          },
          "source_url": {
            "anyOf": [
              {
                "format": "uri",
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          },
          "transformation": {
            "maxLength": 250,
            "minLength": 1,
            "title": "Transformation",
            "type": "string"
          },
          "truth_class": {
            "$ref": "#/components/schemas/TruthClass"
          }
        },
        "required": [
          "source_id",
          "source_record_id",
          "dataset",
          "dataset_version",
          "effective_at",
          "fetched_at",
          "mode",
          "truth_class",
          "raw_payload_hash",
          "transformation",
          "confidence",
          "license"
        ],
        "title": "EvidenceRecord",
        "type": "object"
      },
      "FoundationContractSample": {
        "properties": {
          "assumption": {
            "$ref": "#/components/schemas/Assumption"
          },
          "audit_event": {
            "$ref": "#/components/schemas/AuditEvent"
          },
          "evidence": {
            "$ref": "#/components/schemas/EvidenceRecord"
          },
          "metric": {
            "$ref": "#/components/schemas/MetricEnvelope_float_"
          },
          "source_health": {
            "$ref": "#/components/schemas/SourceHealthRecord"
          }
        },
        "required": [
          "metric",
          "evidence",
          "source_health",
          "assumption",
          "audit_event"
        ],
        "title": "FoundationContractSample",
        "type": "object"
      },
      "FreshnessStatus": {
        "enum": [
          "LIVE",
          "RECENT",
          "CURRENT",
          "STALE",
          "REPLAY",
          "UNAVAILABLE"
        ],
        "title": "FreshnessStatus",
        "type": "string"
      },
      "HealthResponse": {
        "properties": {
          "checked_at": {
            "format": "date-time",
            "title": "Checked At",
            "type": "string"
          },
          "service": {
            "const": "sanjiv-api",
            "default": "sanjiv-api",
            "title": "Service",
            "type": "string"
          },
          "status": {
            "enum": [
              "alive",
              "ready"
            ],
            "title": "Status",
            "type": "string"
          },
          "version": {
            "const": "0.1.0",
            "default": "0.1.0",
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "checked_at"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "MetricEnvelope_float_": {
        "additionalProperties": false,
        "properties": {
          "computed_at": {
            "format": "date-time",
            "title": "Computed At",
            "type": "string"
          },
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "effective_at": {
            "format": "date-time",
            "title": "Effective At",
            "type": "string"
          },
          "evidence_ids": {
            "items": {
              "format": "uuid",
              "type": "string"
            },
            "minItems": 1,
            "title": "Evidence Ids",
            "type": "array"
          },
          "fetched_at": {
            "format": "date-time",
            "title": "Fetched At",
            "type": "string"
          },
          "freshness_status": {
            "$ref": "#/components/schemas/FreshnessStatus"
          },
          "model_version": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Model Version",
            "type": "string"
          },
          "source_refs": {
            "items": {
              "$ref": "#/components/schemas/SourceRef"
            },
            "minItems": 1,
            "title": "Source Refs",
            "type": "array"
          },
          "transformation": {
            "maxLength": 250,
            "minLength": 1,
            "title": "Transformation",
            "type": "string"
          },
          "truth_class": {
            "$ref": "#/components/schemas/TruthClass"
          },
          "unit": {
            "maxLength": 50,
            "minLength": 1,
            "title": "Unit",
            "type": "string"
          },
          "value": {
            "title": "Value",
            "type": "number"
          }
        },
        "required": [
          "value",
          "unit",
          "truth_class",
          "confidence",
          "evidence_ids",
          "source_refs",
          "effective_at",
          "fetched_at",
          "computed_at",
          "freshness_status",
          "transformation",
          "model_version"
        ],
        "title": "MetricEnvelope[float]",
        "type": "object"
      },
      "SourceHealthRecord": {
        "additionalProperties": false,
        "properties": {
          "checked_at": {
            "format": "date-time",
            "title": "Checked At",
            "type": "string"
          },
          "circuit_open": {
            "default": false,
            "title": "Circuit Open",
            "type": "boolean"
          },
          "error_code": {
            "anyOf": [
              {
                "maxLength": 100,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "error_count": {
            "default": 0,
            "minimum": 0.0,
            "title": "Error Count",
            "type": "integer"
          },
          "expected_cadence_seconds": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expected Cadence Seconds"
          },
          "freshness_status": {
            "$ref": "#/components/schemas/FreshnessStatus"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "lag_seconds": {
            "anyOf": [
              {
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Lag Seconds"
          },
          "last_success_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Success At"
          },
          "message_count": {
            "default": 0,
            "minimum": 0.0,
            "title": "Message Count",
            "type": "integer"
          },
          "mode": {
            "$ref": "#/components/schemas/DataMode"
          },
          "source_id": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Source Id",
            "type": "string"
          },
          "stale_after_seconds": {
            "anyOf": [
              {
                "exclusiveMinimum": 0.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stale After Seconds"
          },
          "state": {
            "$ref": "#/components/schemas/SourceState"
          }
        },
        "required": [
          "source_id",
          "state",
          "checked_at",
          "mode",
          "freshness_status"
        ],
        "title": "SourceHealthRecord",
        "type": "object"
      },
      "SourceRef": {
        "additionalProperties": false,
        "properties": {
          "record_id": {
            "maxLength": 500,
            "minLength": 1,
            "title": "Record Id",
            "type": "string"
          },
          "source_id": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Source Id",
            "type": "string"
          }
        },
        "required": [
          "source_id",
          "record_id"
        ],
        "title": "SourceRef",
        "type": "object"
      },
      "SourceState": {
        "enum": [
          "READY",
          "DEGRADED",
          "UNAVAILABLE",
          "RATE_LIMITED",
          "DISABLED"
        ],
        "title": "SourceState",
        "type": "string"
      },
      "TruthClass": {
        "enum": [
          "OBSERVED",
          "DERIVED",
          "INFERRED",
          "MODELED",
          "ASSUMPTION"
        ],
        "title": "TruthClass",
        "type": "string"
      }
    }
  },
  "info": {
    "description": "Keep India's energy moving.",
    "summary": "India's Energy Resilience Command Center",
    "title": "Sanjiv API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/contracts/sample": {
      "get": {
        "description": "Expose the typed Phase 0 sample; no operational feature or live claim.",
        "operationId": "contract_sample_api_v1_contracts_sample_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FoundationContractSample"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Contract Sample",
        "tags": [
          "foundation"
        ]
      }
    },
    "/health/live": {
      "get": {
        "operationId": "liveness_health_live_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness",
        "tags": [
          "health"
        ]
      }
    },
    "/health/ready": {
      "get": {
        "operationId": "readiness_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Readiness",
        "tags": [
          "health"
        ]
      }
    }
  }
}
