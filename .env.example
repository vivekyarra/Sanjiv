# Sanjiv local configuration. Copy to .env; never commit real credentials.
SANJIV_ENV=development
SANJIV_LOG_LEVEL=INFO
SANJIV_API_HOST=0.0.0.0
SANJIV_API_PORT=8000
NEXT_PUBLIC_SANJIV_API_URL=http://localhost:8000
NEXT_PUBLIC_SANJIV_WS_URL=ws://localhost:8000

# Local Docker Compose services
POSTGRES_DB=sanjiv
POSTGRES_USER=sanjiv
POSTGRES_PASSWORD=change-me-local-only
# The application uses asyncpg; Alembic converts this to its synchronous psycopg driver.
DATABASE_URL=postgresql+asyncpg://sanjiv:change-me-local-only@localhost:5432/sanjiv
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me-local-only
MINIO_SECRET_KEY=change-me-local-only
MINIO_BUCKET_RAW=sanjiv-raw
MINIO_BUCKET_REPLAY=sanjiv-replay

# Optional live/periodic source credentials. Missing keys disable that adapter.
AISSTREAM_API_KEY=
SANJIV_AIS_ENABLED=true
SANJIV_AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
# AISStream uses [latitude, longitude] corner pairs. Keep coverage bounded.
SANJIV_AIS_BOUNDING_BOXES=[[[1.0,40.0],[32.0,104.0]]]
SANJIV_AIS_CONNECT_TIMEOUT_SECONDS=10
SANJIV_AIS_SUBSCRIPTION_TIMEOUT_SECONDS=3
SANJIV_AIS_MAX_RETRIES=3
SANJIV_AIS_RECONNECT_BASE_SECONDS=1
SANJIV_AIS_RECONNECT_MAX_SECONDS=30
SANJIV_AIS_QUEUE_SIZE=1000
EIA_API_KEY=
FRED_API_KEY=
UN_COMTRADE_API_KEY=
FIRMS_MAP_KEY=

# Optional provider-neutral scenario interpreter. Structured form works without it.
SANJIV_LLM_PROVIDER=disabled
SANJIV_LLM_MODEL=
OPENAI_API_KEY=

# Maritime operating mode is derived from source capability and every transition is visible/audited.
SANJIV_MARITIME_STORAGE=postgres
SANJIV_MARITIME_AUTOSTART=true
SANJIV_REPLAY_DATASET=data/replay/maritime-watch-v1/manifest.json
SANJIV_REPLAY_SPEED=20
# Loop is for adapter endurance checks; deterministic IDs are deduplicated after the first pass.
SANJIV_REPLAY_LOOP=false
SANJIV_REPLAY_RUNTIME_DIR=data/runtime/replay
SANJIV_GEOFENCE_FIXTURE=data/fixtures/maritime/geofences.geojson
SANJIV_STALE_AFTER_SECONDS=300
SANJIV_WEBSOCKET_HEARTBEAT_SECONDS=10
SANJIV_SOURCE_TIMEOUT_SECONDS=10
SANJIV_SOURCE_MAX_RETRIES=3
SANJIV_SOLVER_TIMEOUT_SECONDS=4
SANJIV_ALLOWED_ORIGINS=http://localhost:3000
